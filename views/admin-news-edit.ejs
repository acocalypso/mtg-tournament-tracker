<%- include("partials/header", { title }) %>

<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />

<section class="hero">
  <h1><%= t('admin.newsEdit') %></h1>
  <p><%= t('admin.newsEditHint') %></p>
  <p><a class="table-link" href="/admin/news"><%= t('admin.newsBackToAdmin') %></a></p>
</section>

<% if (message) { %>
  <p class="flash success"><%= message %></p>
<% } %>
<% if (error) { %>
  <p class="flash error"><%= error %></p>
<% } %>

<%- include("partials/admin-nav", { active: "news-list", canManageUsers }) %>

<section class="card">
  <form id="news-edit-form" method="post" action="/admin/news/<%= article.id %>/update" class="stack-form" enctype="multipart/form-data">
    <label>
      <%= t('admin.newsTitle') %>
      <input type="text" name="title" required maxlength="180" value="<%= article.title %>" />
    </label>

    <label>
      <%= t('admin.newsContent') %>
      <div id="news-edit-editor" class="quill-editor"><%- article.content %></div>
      <input type="hidden" id="news-edit-content-html" name="content_html" />
    </label>

    <% if (article.image_url) { %>
      <div>
        <p class="subtle"><%= t('admin.newsCurrentImage') %></p>
        <img class="news-image" src="<%= article.image_url %>" alt="<%= article.title %>" loading="lazy" />
      </div>
    <% } %>

    <label>
      <%= t('admin.newsReplaceImage') %>
      <input type="file" name="image" accept="image/png,image/jpeg,image/webp,image/gif" />
      <small class="subtle"><%= t('admin.newsImageHint') %></small>
    </label>

    <% if (article.image_url) { %>
      <label>
        <%= t('admin.newsRemoveImage') %>
        <select name="remove_image">
          <option value="0"><%= t('admin.disabled') %></option>
          <option value="1"><%= t('admin.enabled') %></option>
        </select>
      </label>
    <% } %>

    <label>
      <%= t('admin.newsVisibility') %>
      <select name="is_published" required>
        <option value="1" <%= article.is_published ? "selected" : "" %>><%= t('admin.newsPublished') %></option>
        <option value="0" <%= !article.is_published ? "selected" : "" %>><%= t('admin.newsDraft') %></option>
      </select>
    </label>
    <label>
      <%= t('admin.articleType') %>
      <select id="article-type" name="article_type" required>
        <option value="news" <%= article.article_type !== 'footer_page' ? "selected" : "" %>><%= t('admin.articleTypeNews') %></option>
        <option value="footer_page" <%= article.article_type === 'footer_page' ? "selected" : "" %>><%= t('admin.articleTypeFooterPage') %></option>
      </select>
    </label>
    <label id="page-slug-wrapper" class="<%= article.article_type === 'footer_page' ? '' : 'hidden-field' %>">
      <%= t('admin.footerSlug') %>
      <input type="text" name="page_slug" maxlength="180" value="<%= article.page_slug || '' %>" placeholder="<%= t('placeholders.footerSlug') %>" />
      <small class="subtle"><%= t('admin.footerSlugHint') %></small>
    </label>

    <label>
      <%= t('admin.newsPublishedAt') %>
      <input type="datetime-local" name="published_at" value="<%= new Date(article.published_at).toISOString().slice(0, 16) %>" />
    </label>

    <button type="submit"><%= t('admin.newsUpdate') %></button>
  </form>
</section>

<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
  (function () {
    const form = document.getElementById("news-edit-form");
    const editorEl = document.getElementById("news-edit-editor");
    const hidden = document.getElementById("news-edit-content-html");
    const articleTypeSelect = document.getElementById("article-type");
    const slugWrapper = document.getElementById("page-slug-wrapper");

    if (!form || !editorEl || !hidden || !window.Quill) {
      return;
    }

    const quill = new window.Quill(editorEl, {
      theme: "snow",
      modules: {
        toolbar: [["bold", "italic", "underline"], [{ header: [2, 3, false] }], [{ list: "ordered" }, { list: "bullet" }], ["link", "blockquote", "code-block"], ["clean"]],
      },
    });

    form.addEventListener("submit", () => {
      hidden.value = quill.root.innerHTML;
    });

    function syncSlugVisibility() {
      if (!articleTypeSelect || !slugWrapper) {
        return;
      }
      slugWrapper.classList.toggle("hidden-field", articleTypeSelect.value !== "footer_page");
    }

    if (articleTypeSelect && slugWrapper) {
      articleTypeSelect.addEventListener("change", syncSlugVisibility);
      syncSlugVisibility();
    }
  })();
</script>

<%- include("partials/footer") %>
