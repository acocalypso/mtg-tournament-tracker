<!DOCTYPE html>
<html lang="<%= currentLocale || 'en' %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | <%= siteName || t('app.title') %></title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script>
      (function () {
        try {
          const saved = localStorage.getItem("theme");
          const prefersDark =
            typeof window.matchMedia === "function" &&
            window.matchMedia("(prefers-color-scheme: dark)").matches;
          const theme = saved === "dark" || saved === "light" ? saved : (prefersDark ? "dark" : "light");
          document.documentElement.setAttribute("data-theme", theme);
        } catch (_error) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="backdrop"></div>
    <header class="site-header">
      <a class="brand" href="/"><%= siteName || t('brand') %></a>
      <nav class="main-nav">
        <a href="/news"><%= t('nav.news') %></a>
        <a href="/leaderboard"><%= t('nav.leaderboard') %></a>
        <a href="/meta"><%= t('nav.meta') %></a>
        <a href="/tournaments"><%= t('nav.tournaments') %></a>
        <% if (isAuthenticated) { %>
          <a href="/profile"><%= t('nav.profile') %></a>
          <% if (isStaff) { %>
            <a href="/admin"><%= t('nav.admin') %></a>
          <% } %>
          <form method="post" action="/logout" class="nav-logout-form">
            <%- include("csrf") %>
            <button type="submit" class="nav-logout-btn"><%= t('nav.logout') %></button>
          </form>
        <% } else { %>
          <a href="/login"><%= t('nav.login') %></a>
          <a href="/register"><%= t('nav.register') %></a>
        <% } %>
        <div class="nav-lang-switch" aria-label="<%= t('lang.label') %>">
          <span class="nav-lang-label"><%= t('lang.label') %></span>
          <form method="post" action="/language" class="nav-lang-form">
            <%- include("csrf") %>
            <input type="hidden" name="return_to" value="<%= requestPath || '/' %>" />
            <input type="hidden" name="locale" value="en" />
            <button
              type="submit"
              class="nav-flag-btn <%= currentLocale === 'en' ? 'is-active' : '' %>"
              title="<%= t('lang.english') %>"
              aria-label="<%= t('lang.english') %>"
            >
              <span aria-hidden="true">🇬🇧</span>
            </button>
          </form>
          <form method="post" action="/language" class="nav-lang-form">
            <%- include("csrf") %>
            <input type="hidden" name="return_to" value="<%= requestPath || '/' %>" />
            <input type="hidden" name="locale" value="de" />
            <button
              type="submit"
              class="nav-flag-btn <%= currentLocale === 'de' ? 'is-active' : '' %>"
              title="<%= t('lang.german') %>"
              aria-label="<%= t('lang.german') %>"
            >
              <span aria-hidden="true">🇩🇪</span>
            </button>
          </form>
        </div>
        <button
          type="button"
          id="theme-toggle"
          class="nav-theme-btn"
          aria-label="<%= t('theme.label') %>"
          title="<%= t('theme.label') %>"
          data-theme-base-label="<%= t('theme.label') %>"
          data-label-light="<%= t('theme.light') %>"
          data-label-dark="<%= t('theme.dark') %>"
          data-icon-light="☀"
          data-icon-dark="◐"
        ></button>
      </nav>
    </header>
    <script>
      (function () {
        const themeToggle = document.getElementById("theme-toggle");
        if (!themeToggle) {
          return;
        }

        function getCurrentTheme() {
          const current = document.documentElement.getAttribute("data-theme");
          return current === "dark" ? "dark" : "light";
        }

        function renderThemeButton(theme) {
          const icon = theme === "dark" ? themeToggle.dataset.iconDark : themeToggle.dataset.iconLight;
          const label = theme === "dark" ? themeToggle.dataset.labelDark : themeToggle.dataset.labelLight;
          const baseLabel = themeToggle.dataset.themeBaseLabel || "Theme";
          themeToggle.textContent = icon || "☀";
          themeToggle.setAttribute("aria-label", `${baseLabel}: ${label}`);
          themeToggle.setAttribute("title", `${baseLabel}: ${label}`);
          themeToggle.setAttribute("aria-pressed", theme === "dark" ? "true" : "false");
        }

        function applyTheme(theme) {
          document.documentElement.setAttribute("data-theme", theme);
          renderThemeButton(theme);
          try {
            localStorage.setItem("theme", theme);
          } catch (_error) {
            // Ignore storage failures.
          }
        }

        renderThemeButton(getCurrentTheme());

        themeToggle.addEventListener("click", function () {
          const nextTheme = getCurrentTheme() === "dark" ? "light" : "dark";
          applyTheme(nextTheme);
        });
      })();
    </script>
    <main class="page-shell">
