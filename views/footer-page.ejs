<%- include("partials/header", { title }) %>

<section class="hero">
  <h1><%= page.title %></h1>
</section>

<section class="card">
  <% if (page.image_url) { %>
    <img class="news-image" src="<%= page.image_url %>" alt="<%= page.title %>" loading="lazy" />
  <% } %>
  <div class="news-content"><%- page.content %></div>
</section>

<%- include("partials/footer") %>
